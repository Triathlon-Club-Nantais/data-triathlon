# Connexion base de données (Supabase en prod, SQLite en local par défaut)
DATABASE_URL=sqlite:///./triathlon.db

# Origines CORS autorisées (CSV). Restreindre en production.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Cache TTL dynamique (secondes) — valeurs par défaut : 10 min / 30 j
# CACHE_TTL_IN_PROGRESS_SECONDS=600
# CACHE_TTL_FINISHED_SECONDS=2592000
