GITHUB_PAT=
RENDER_API_KEY=

# Secret partagé du cron « keep-warm » (frontend/app/api/cron/keep-warm/route.ts).
# Un cron externe (serveur Azure) appelle GET /api/cron/keep-warm en envoyant
# l'en-tête `Authorization: Bearer $CRON_SECRET` ; la route rejette (401) sinon.
# Générer une valeur : openssl rand -hex 32. NE JAMAIS committer la vraie valeur.
CRON_SECRET=
