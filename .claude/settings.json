{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git stash list*)",
      "Bash(git show*)",
      "Bash(git add backend/*)",
      "Bash(git add frontend/*)",
      "Bash(git add tests/*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git stash*)",
      "Bash(pytest*)",
      "Bash(python -m pytest*)",
      "Bash(python backend/*)",
      "Bash(pip install*)",
      "Bash(pip list*)",
      "Bash(pip show*)",
      "Bash(uvicorn*)",
      "Bash(npm install*)",
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npm run lint*)",
      "Bash(npm test*)",
      "Bash(npm list*)",
      "Bash(npx vite*)",
      "Bash(npx playwright*)",
      "Bash(npx eslint*)",
      "Bash(ls*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(which*)",
      "Bash(pwd*)",
      "Bash(curl -s http://localhost*)",
      "Bash(curl -X * http://localhost*)",
      "Bash(rtk*)",
      "Read(/**/.env.example)"
    ],
    "ask": [
      "Bash(git add .)",
      "Bash(git add -A*)",
      "Bash(git add -u*)",
      "Bash(git push*)",
      "Bash(git branch -D*)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",
      "Bash(npx *)",
      "Bash(psql*)",
      "Bash(python -c*)",
      "Bash(rm *)",
      "mcp__github__push_files",
      "mcp__github__create_or_update_file",
      "mcp__github__delete_file",
      "mcp__github__merge_pull_request",
      "mcp__github__create_pull_request"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -f*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(chmod 777*)",
      "Bash(sudo*)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(wget * | sh*)",
      "Read(/**/.env)",
      "Read(/**/.env.*)"
    ]
  }
}
